{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/main"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "includeFiles": [
        "database/**",
        "frontend/**",
        "db/**",
        "services/**",
        "controller/**",
        "models/**",
        "classes/**",
        "exporter/**",
        "*.py"
      ]
    }
  }
}
